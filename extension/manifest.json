{
  "manifest_version": 3,
  "name": "PhishShield",
  "version": "1.0",

  "description": "Detect phishing URLs and suspicious websites",

  "permissions": [
    "activeTab",
    "tabs",
    "scripting"
  ],

  "host_permissions": [
    "http://127.0.0.1:5000/*",
    "https://mail.google.com/*"
  ],

  "content_scripts": [
    {
      "matches": [
        "https://mail.google.com/*"
      ],
      "js": [
        "content.js"
      ]
    }
  ],
  
  "action": {
    "default_popup": "popup.html"
  }
}
